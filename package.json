{
  "name": "cypress-interview-template",
  "version": "1.0.0",
  "description": "Progressive E2E Cypress exercise template for interview candidates",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:round1": "cypress run --spec 'cypress/e2e/01-login.cy.js'",
    "cy:run:round3": "cypress run --spec 'cypress/e2e/02-products.cy.js'",
    "cy:run:round4": "cypress run --spec 'cypress/e2e/03-cart.cy.js'",
    "cy:run:round6": "cypress run --spec 'cypress/e2e/04-checkout.cy.js'",
    "pw:test": "playwright test",
    "pw:test:round1": "playwright test tests/01-login.spec.js",
    "pw:test:round3": "playwright test tests/02-products.spec.js",
    "pw:test:round4": "playwright test tests/03-cart.spec.js",
    "pw:test:round6": "playwright test tests/04-checkout.spec.js",
    "pw:open": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "cypress": "^13.17.0"
  }
}
